<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.dao.RiZhiDao">

    <resultMap type="com.entity.RiZhiEntity" id="rizhiMap">
        <result property="caozuoyonghu" column="caozuoyonghu"/>
        <result property="caozuoleixing" column="caozuoleixing"/>
        <result property="caozuoneirong" column="caozuoneirong"/>
        <result property="caozuoshijian" column="caozuoshijian"/>
        <result property="ipdizhi" column="ipdizhi"/>
        <result property="liulanqi" column="liulanqi"/>
        <result property="addtime" column="addtime"/>
    </resultMap>

	<select id="selectListVO"
		resultType="com.entity.vo.RiZhiVO" >
		SELECT * FROM rizhi  rizhi         
        <where> 1=1 </where>
	</select>
	
	<select id="selectVO"
		resultType="com.entity.vo.RiZhiVO" >
		SELECT  rizhi.* FROM rizhi  rizhi 		
 		<where> 1=1 </where>
	</select>

    <select id="selectListView"
		resultType="com.entity.view.RiZhiView" >

		SELECT  rizhi.* FROM rizhi  rizhi          
        <where> 1=1 </where>
	</select>
	
	<select id="selectView"
		resultType="com.entity.view.RiZhiView" >
		SELECT * FROM rizhi  rizhi <where> 1=1 </where>
	</select>
	
</mapper>
