<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.dao.ShipinDao">

    <resultMap type="com.entity.ShipinEntity" id="shipinMap">
        <result property="biaoti" column="biaoti"/>
        <result property="fenlei" column="fenlei"/>
        <result property="lianjie" column="lianjie"/>
        <result property="fengmian" column="fengmian"/>
        <result property="miaoshu" column="miaoshu"/>
        <result property="dianzanshu" column="dianzanshu"/>
        <result property="shoucangshu" column="shoucangshu"/>
        <result property="clicknum" column="clicknum"/>
    </resultMap>

	<select id="selectListVO"
		resultType="com.entity.vo.ShipinVO" >
		SELECT * FROM shipin  shipin         
        <where> 1=1 </where>
	</select>
	
	<select id="selectVO"
		resultType="com.entity.vo.ShipinVO" >
		SELECT  shipin.* FROM shipin  shipin  
		<where> 1=1 </where>
	</select>

    <select id="selectListView"
		resultType="com.entity.view.ShipinView" >

		SELECT  shipin.* FROM shipin  shipin          
        <where> 1=1 </where>
	</select>
	
	<select id="selectView"
		resultType="com.entity.view.ShipinView" >
		SELECT * FROM shipin  shipin <where> 1=1 </where>
	</select>
	

</mapper>
